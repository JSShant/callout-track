{
  "name": "pumpfun-callout-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Polls pump.fun's callout feed for first-ever-callout and newly-linked-X events, alerting via Telegram.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
