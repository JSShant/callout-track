# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Bearer token from a burner pump.fun account's logged-in session.
# See README.md "Getting your session token" for how to extract this.
PUMPFUN_SESSION_TOKEN=

# From @BotFather in Telegram after running /newbot.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id, from messaging @userinfobot.
TELEGRAM_CHAT_ID=

# Path to the local SQLite state file. In CI this is checked out from the
# "state" branch; locally it will just be created on first run.
STATE_DB_PATH=./state/callouts.db

# How many known callers to re-check for X-link status per run (Event B).
# Higher = faster full-population coverage, more API calls per run.
X_LINK_RECHECK_BATCH_SIZE=25
